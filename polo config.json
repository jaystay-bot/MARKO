  "output": {
    "resolution": "1280x720",
    "format": "mp4",
    "codec": "h264",
    "audio_codec": "aac",
    "max_duration_seconds": 90,
    "max_file_size_mb": 50,
    "output_dir": "./polo_output",
    "filename_template": "POLO_{app}_{version}_{date}.mp4"
