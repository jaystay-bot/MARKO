    "model": "eleven_monolingual_v1",
    "stability": 0.5,
    "similarity_boost": 0.75,
    "monthly_char_limit": 10000,
    "char_usage_log": "./polo_output/elevenlabs_usage.json",
    "fallback": "web_speech_api"
  },

  "web_speech_fallback": {
    "voice": "Google US English",
    "rate": 0.9,
    "pitch": 1.0,
    "volume": 1.0
  },

  "recording": {
    "cursor_style": "smooth",
