    "scroll_behavior": "smooth",
    "viewport_width": 1280,
    "viewport_height": 720,
    "headless": false,
    "slow_mo_ms": 80
  },

  "storage": {
    "google_drive_folder": "POLO Videos",
    "backup": "github_video_assets",
    "tracker_sheet": "POLO Tracker"
  },

